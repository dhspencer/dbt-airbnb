te", "started_at": "2026-04-06T14:42:53.418475Z", "completed_at": "2026-04-06T14:42:53.418475Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.007238626480102539, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.airbnb.unique_dim_listings_clean_listing_id.8c10b32ab7", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    listing_id as unique_field,\n    count(*) as n_records\n\nfrom AIRBNB.DEV.dim_listings_clean\nwhere listing_id is not null\ngroup by listing_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T14:42:53.425641Z", "completed_at": "2026-04-06T14:42:53.431680Z"}, {"name": "execute", "started_at": "2026-04-06T14:42:53.431680Z", "completed_at": "2026-04-06T14:42:53.431680Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.013959407806396484, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.airbnb.mart_fullmoom_reviews", "compiled": true, "compiled_code": "-- This model adds a 'is_full_moon' column to the fct_reviews table\n-- indicating whether the review was written the day after a full moon.\n\n\nWITH fct_reviews AS (\n    SELECT * FROM AIRBNB.DEV.fct_reviews\n),\nfull_moon_dates AS (\n    SELECT * FROM AIRBNB.DEV.seed_full_moon_dates\n)\n\nSELECT\n  r.*,\n  CASE\n    WHEN fm.full_moon_date IS NULL THEN 'not full moon'\n    ELSE 'full moon'\n  END AS is_full_moon\nFROM\n  fct_reviews\n  r\n  LEFT JOIN full_moon_dates\n  fm\n  ON (TO_DATE(r.review_date) = DATEADD(DAY, 1, fm.full_moon_date))", "relation_name": "AIRBNB.DEV.mart_fullmoom_reviews", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T14:42:53.439135Z", "completed_at": "2026-04-06T14:42:53.443162Z"}, {"name": "execute", "started_at": "2026-04-06T14:42:53.443162Z", "completed_at": "2026-04-06T14:42:53.443162Z"}], "thread_id": "Thread-2 (worker)", "executi