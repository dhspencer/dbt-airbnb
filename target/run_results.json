{"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T14:42:53.149504Z", "completed_at": "2026-04-06T14:42:53.157753Z"}, {"name": "execute", "started_at": "2026-04-06T14:42:53.157753Z", "completed_at": "2026-04-06T14:42:53.157753Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.008248567581176758, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.airbnb.consistent_created_at", "compiled": true, "compiled_code": "SELECT \r\nlisting.LISTING_ID\r\n, listing.CREATED_AT\r\n, reviews.REVIEW_DATE\r\nFROM AIRBNB.DEV.DIM_LISTINGS_WITH_HOSTS listing\r\nJOIN AIRBNB.DEV.FCT_REVIEWS reviews\r\nON listing.LISTING_ID = reviews.LISTING_ID\r\nWHERE REVIEW_DATE < CREATED_AT", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T14:42:53.157753Z", "completed_at": "2026-04-06T14:42:53.172067Z"}, {"name": "execute", "started_at": "2026-04-06T14:42:53.174075Z", "completed_at": "2026-04-06T14:42:53.174075Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.01632237434387207, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.airbnb.dim_hosts_clean", "compiled": true, "compiled_code": "-- cleaning the data in the hosts table src_hosts\n\nWITH  __dbt__cte__src_hosts as (\n-- import raw hosts\nWITH raw_hosts AS\n(\nSELECT * FROM AIRBNB.raw.raw_hosts\n)\nSELECT \n    id AS host_id,\n    name AS host_name,\n    is_superhost,\n    created_at,\n    updated_at\nFROM raw_hosts\n), src_hosts AS \n(\n        SELECT * FROM __dbt__cte__src_hosts\n)\nSELECT \n   host_id,\n   COALESCE(host_name,'Anonymous') AS host_name,\n   is_superhost,\n   created_at,\n   updated_at\nFROM src_hosts", "relation_name": "AIRBNB.DEV.dim_hosts_clean", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T14:42:53.260695Z", "completed_at": "2026-04-06T14:42:53.276762Z"}, {"name": "execute", "started_at": "2026-04-06T14:42:53.286719Z", "completed_at": "2026-04-06T14:42:53.286719Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.02602410316467285, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.airbnb.dim_listings_clean", "compiled": true, "compiled_code": "--cleaning the data in the listings table src_listings\n\nWITH  __dbt__cte__src_listings as (\n-- import raw_listings\nWITH raw_listings AS \n(\n        SELECT * FROM AIRBNB.raw.raw_listings\n)\nSELECT \n   id AS listing_id,\n   listing_url,\n   name AS listing_name,\n   room_type,\n   minimum_nights,\n   host_id,\n   price AS price_str,\n   created_at,\n   updated_at\nFROM raw_listings\n), src_listings  AS \n(\n        SELECT * FROM __dbt__cte__src_listings\n)\n\nSELECT \n   listing_id,\n   listing_name,\n   room_type,\n   CASE WHEN minimum_nights = 0 \n        THEN 1 \n        ELSE minimum_nights END AS minimum_nights,\n   host_id,\n   REPLACE(price_str, '$', '') :: NUMBER(10,2) AS price,\n   created_at,\n   updated_at\nFROM src_listings\n-- LIMIT 10", "relation_name": "AIRBNB.DEV.dim_listings_clean", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T14:42:53.291578Z", "completed_at": "2026-04-06T14:42:53.309178Z"}, {"name": "execute", "started_at": "2026-04-06T14:42:53.309702Z", "completed_at": "2026-04-06T14:42:53.309702Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.02298283576965332, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.airbnb.fct_reviews", "compiled": true, "compiled_code": "-- create fact table for reviews\n\n\nWITH  __dbt__cte__src_reviews as (\n-- import raw reviews\nWITH raw_reviews AS\n(\nSELECT * FROM AIRBNB.raw.raw_reviews\n)\nSELECT \n    listing_id,\n    date AS review_date,\n    reviewer_name,\n    comments AS review_text,\n    sentiment AS review_sentiment\nFROM raw_reviews\n), src_reviews AS \n(\n    SELECT * FROM __dbt__cte__src_reviews\n)\nSELECT \n    *\nFROM src_reviews\nWHERE review_text IS NOT NULL\n\n  AND review_date > (SELECT COALESCE(MAX(review_date), '1900-01-01') FROM AIRBNB.DEV.fct_reviews)\n", "relation_name": "AIRBNB.DEV.fct_reviews", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T14:42:53.316519Z", "completed_at": "2026-04-06T14:42:53.316519Z"}, {"name": "execute", "started_at": "2026-04-06T14:42:53.316519Z", "completed_at": "2026-04-06T14:42:53.316519Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.0068171024322509766, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.airbnb.dim_listings_with_hosts", "compiled": true, "compiled_code": "-- create dimension table for listing with hosts details\nWITH\nl AS (\n    SELECT\n        *\n    FROM\n        AIRBNB.DEV.dim_listings_clean\n),\nh AS (\n    SELECT *\n    FROM AIRBNB.DEV.dim_hosts_clean\n)\n\nSELECT\n    l.listing_id,\n    l.listing_name,\n    l.room_type,\n    l.minimum_nights,\n    l.price,\n    l.host_id,\n    h.host_name,\n    h.is_superhost as host_is_superhost,\n    l.created_at,\n    GREATEST(l.updated_at, h.updated_at) as updated_at\nFROM l\nLEFT JOIN h ON (h.host_id = l.host_id)", "relation_name": "AIRBNB.DEV.dim_listings_with_hosts", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T14:42:53.328286Z", "completed_at": "2026-04-06T14:42:53.343544Z"}, {"name": "execute", "started_at": "2026-04-06T14:42:53.343544Z", "completed_at": "2026-04-06T14:42:53.343544Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.018152475357055664, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.airbnb.accepted_values_dim_listings_clean_room_type__Entire_home_apt__Private_room__Shared_room__Hotel_room.9fa24c2dae", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        room_type as value_field,\n        count(*) as n_records\n\n    from AIRBNB.DEV.dim_listings_clean\n    group by room_type\n\n)\n\nselect *\nfrom all_values\nwhere value_field not in (\n    'Entire home/apt','Private room','Shared room','Hotel room'\n)\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T14:42:53.351732Z", "completed_at": "2026-04-06T14:42:53.359951Z"}, {"name": "execute", "started_at": "2026-04-06T14:42:53.359951Z", "completed_at": "2026-04-06T14:42:53.359951Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.016406536102294922, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.airbnb.minimum_row_count_dim_listings_clean_1000.f75411b637", "compiled": true, "compiled_code": "\n    SELECT\n    COUNT(*) AS row_count\n    FROM AIRBNB.DEV.dim_listings_clean\n    HAVING COUNT(*) < 1000\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T14:42:53.366067Z", "completed_at": "2026-04-06T14:42:53.379641Z"}, {"name": "execute", "started_at": "2026-04-06T14:42:53.379641Z", "completed_at": "2026-04-06T14:42:53.379641Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.013573884963989258, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.airbnb.not_null_dim_listings_clean_host_id.13b3bbdd44", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect host_id\nfrom AIRBNB.DEV.dim_listings_clean\nwhere host_id is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-06T14:42:53.383653Z", "completed_at": "2026-04-06T14:42:53.387669Z"}, {"name": "execute", "started_at": "2026-04-06T14:42:53.387669Z", "completed_at": "2026-04-06T14:42:53.387669Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.008027791976928711, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.airbnb.not_null_dim_listings