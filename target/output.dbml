Table "model.airbnb.dim_listings_clean" {
  "listing_id" "number" [note: "Primiary key for each listing."]
  "listing_name" "text"
  "room_type" "text" [note: "The type of room being offered."]
  "minimum_nights" "number" [note: "Minimum number of nights required to rent this property.\r\n\r\nKeep in mind that old listings have `minimum nights` set to 0 in the source tables. The cleansing algorithm updates this to `1`."]
  "host_id" "number" [note: "Foreign key to the dim_hosts_clean table."]
  "price" "number"
  "created_at" "timestamp_ntz"
  "updated_at" "timestamp_ntz"

  Note: "Cleaned dimension table which contains Airbnb listings."
}
