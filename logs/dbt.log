    as (-- create dimension table for listing with hosts details
WITH
l AS (
    SELECT
        *
    FROM
        AIRBNB.DEV.dim_listings_clean
),
h AS (
    SELECT *
    FROM AIRBNB.DEV.dim_hosts_clean
)

