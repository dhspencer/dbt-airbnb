WITH  __dbt__cte__src_listings as (
-- import raw_listings
WITH raw_listings AS 
(
        SELECT * FROM AIRBNB.raw.raw_listings
)
SELECT 
   id AS listing_id,
   listing_url,
   name AS listing_name,
   room_type,
   minimum_nights,
   host_id,
   price AS price_str,
   created_at,
   updated_at
FROM raw_listings
), src_listings  AS 
(
        SELECT * FROM __dbt__cte__src_listings
)

SELECT 
