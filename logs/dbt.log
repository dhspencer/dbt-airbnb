    as (-- This model adds a 'is_full_moon' column to the fct_reviews table
-- indicating whether the review was written the day after a full moon.


WITH fct_reviews AS (
    SELECT * FROM AIRBNB.DEV.fct_reviews
),
full_moon_dates AS (
    SELECT * FROM AIRBNB.DEV.seed_full_moon_dates
)

SELECT
  r.*,
  CASE
    WHEN fm.full_moon_date IS NULL THEN 'not full moon'
    ELSE 'full moon'
  END AS is_full_moon
FROM
  fct_reviews
  r
  LEFT JOIN full_moon_dates
  fm
  ON (TO_DATE(r.review_date) = DATEADD(DAY, 1, fm.full_moon_date))
    )

/* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "airbnb", "target_name": "dev", "node_id": "model.airbnb.mart_fullmoom_reviews"} */;
